runDevServer() {
	if [ -f "yarn.lock" ]; then
		package_manager="yarn"
	elif [ -f "pnpm-lock.yaml" ]; then
		package_manager="pnpm"
	elif [ -f "package.json" ]; then
		package_manager="npm"
	else
		echo "Neither yarn.lock nor package.json found. Are you in a JavaScript project directory?"
		return 1
	fi

	if [ -f "package.json" ]; then
		if grep -q '"dev"' package.json; then
			script="dev"
		elif grep -q '"start"' package.json; then
			script="start"
		else
			echo "Neither 'dev' nor 'start' script found in package.json"
			return 1
		fi
	else
		script="start"
	fi

	if [ "$package_manager" = "npm" ]; then
		echo "Running: npm run $script"
		npm run "$script"
	elif [ "$package_manager" = "pnpm" ]; then
		echo "Running: pnpm run $script"
		pnpm run "$script"
	else
		echo "Running: $package_manager $script"
		$package_manager $script
	fi
}

installPackages() {
  if [ -f "yarn.lock" ]; then
    yarn
  elif [ -f "pnpm-lock.yaml" ]; then
    pnpm install
  elif [ -f "package.json" ]; then
    npm install
  else
    echo "Neither yarn.lock nor package.json found. Are you in a JavaScript project directory?"
    return 1
  fi
}

